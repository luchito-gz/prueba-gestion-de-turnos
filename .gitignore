#Contenido para que no se suban archivos basura al repositorio de GitHub. Este archivo se llama .gitignore y se coloca en la raíz del proyecto.

# Python
__pycache__/
venv/
*.pyc
.env

# SQLite local (smoke tests, no debe ir al repo)
*.db
*.db-journal
*.sqlite
*.sqlite3

# React / Node
node_modules/
dist/
.DS_Storefrontend/vite.config.js.timestamp*
