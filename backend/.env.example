# Archivo de ejemplo para variables de entorno del backend.
# Copiá este archivo como .env y completá con tus valores reales.
# ⚠️  NUNCA commitees el .env real — ya está protegido por .gitignore.

# --- Aplicación ---
APP_NAME=TurnoIA
ENVIRONMENT=development   # development | staging | production

# --- Base de datos ---
# PostgreSQL local (desarrollo):
DATABASE_URL=postgresql://user:password@localhost:5432/turno_ia_dev
# PostgreSQL en producción (Railway / Render / Supabase):
# DATABASE_URL=postgresql://user:password@host:5432/turno_ia_prod

# --- JWT (autenticación del panel — S1) ---
# Generá tu secreto con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=cambiame_por_un_secreto_largo_y_aleatorio
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440   # 24 horas

# --- Twilio (WhatsApp webhook — C1) ---
# Conseguís estos valores en: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Número principal del negocio (ej: +5491112345678)
TWILIO_WHATSAPP_NUMBER=
# Número de origen Twilio Sandbox en formato whatsapp: (ej: whatsapp:+14155238886)
TWILIO_WHATSAPP_FROM=
